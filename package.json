{
  "name": "emily-css",
  "version": "1.0.3",
  "description": "A config-driven utility CSS framework. Define your brand once, generate the CSS.",
  "main": "src/index.js",
  "bin": {
    "emily-css": "./bin/emilyui.js"
  },
  "files": [
    "bin/",
    "src/",
    "dist/emily.css",
    "dist/emily.min.css",
    "fonts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node src/index.js",
    "dev": "nodemon src/index.js",
    "init": "node src/init.js",
    "test": "node tests/test.js"
  },
  "keywords": [
    "css",
    "design-system",
    "components",
    "config-driven",
    "utility-css",
    "accessibility",
    "drupal",
    "legacy",
    "no-build-step"
  ],
  "author": "Andy Terry",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
