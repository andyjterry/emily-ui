{
  "name": "emily-css",
  "version": "1.2.1",
  "description": "A config-driven utility CSS framework. Define your brand once, generate the CSS.",
  "main": "src/index.js",
  "bin": {
    "emily-css": "bin/emilyui.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:full": "nodemon src/index.js -- --keep-full",
    "init": "node src/init.js",
    "test": "node tests/test.js",
    "emily:showcase": "node src/showcase.js",
    "commit": "node scripts/commit.js",
    "release": "node scripts/release.js",
    "ship": "node scripts/ship.js",
    "emily:build": "emily-css build",
    "emily:watch": "emily-css watch",
    "emily:help": "emily-css help"
  },
  "keywords": [
    "css",
    "design-system",
    "components",
    "config-driven",
    "utility-css",
    "accessibility",
    "drupal",
    "legacy",
    "no-build-step"
  ],
  "author": "Andy Terry",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "cross-spawn": "^7.0.6",
    "enquirer": "^2.4.1",
    "fast-glob": "^3.3.3",
    "ora": "^5.4.1"
  }
}
